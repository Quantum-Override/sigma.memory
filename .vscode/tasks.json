{
    "version": "2.0.0",
    "tasks": [
        {
            "label": "build",
            "type": "shell",
            "command": "cbuild",
            "group": {
                "kind": "build",
                "isDefault": true
            },
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            },
            "problemMatcher": "$gcc"
        },
        {
            "label": "clean",
            "type": "shell",
            "command": "cbuild clean",
            "group": "build",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "test",
            "type": "shell",
            "command": "ctest",
            "group": "test",
            "presentation": {
                "echo": true,
                "reveal": "always",
                "focus": false,
                "panel": "shared"
            }
        },
        {
            "label": "build active test",
            "type": "shell",
            "command": "gcc -g -c src/memory.c -o build/memory.o -Iinclude && gcc -g -o build/test/${fileBasenameNoExtension} test/${fileBasename} build/memory.o -Iinclude -I/usr/include -lstest",
            "group": "build",
            "problemMatcher": [
                "$gcc"
            ]
        }
    ]
}